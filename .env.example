# Core
MONGO_URI=mongodb://localhost:27017/template_backend
PORT=7000
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=30d

# Optional: comma-separated browser origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional: directory containing prompt-scrapear-productos*.md (overrides default search paths)
# PROVIDER_PROMPTS_DIR=/absolute/path/to/docs

# File uploads (Cloudinary)
CLOUDINARY_CLOUD=your_cloudinary_cloud
CLOUDINARY_KEY=your_cloudinary_key
CLOUDINARY_SECRET=your_cloudinary_secret
